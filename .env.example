# Required
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
JWT_SECRET=generate-a-long-random-string-here

# Server
PORT=3000
NODE_ENV=development

# Optional — AI settings
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_PROMPT_LENGTH=12000
MAX_OUTPUT_TOKENS=1000
PRO_MAX_OUTPUT_TOKENS=2048
BUSINESS_MAX_OUTPUT_TOKENS=4096
FREE_DAILY_LIMIT=3
MAX_UPLOAD_BYTES=5242880
MAX_DOCUMENT_CHARS=15000

# Security
IP_HASH_SALT=random-salt-for-ip-hashing
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MIN=30
GENERATE_LIMIT_PER_MIN=10

# Stripe (required for real payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_LINK_PRO=https://buy.stripe.com/your-pro-monthly-link
STRIPE_LINK_PRO_ANNUAL=https://buy.stripe.com/your-pro-annual-link
STRIPE_LINK_BUSINESS=https://buy.stripe.com/your-business-monthly-link
STRIPE_LINK_BUSINESS_ANNUAL=https://buy.stripe.com/your-business-annual-link
STRIPE_LINK_PACK_50=https://buy.stripe.com/your-50-credits-link
STRIPE_LINK_PACK_200=https://buy.stripe.com/your-200-credits-link
STRIPE_LINK_PACK_500=https://buy.stripe.com/your-500-credits-link
STRIPE_LINK_PACK_1000=https://buy.stripe.com/your-1000-credits-link

# Demo checkout (dev only — never enable in production)
ALLOW_DEMO_CHECKOUT=false

# Contact
CONTACT_EMAIL=hello@sparknous.com

# Database (optional — defaults to ./data/writeflow.db)
# DATABASE_PATH=./data/writeflow.db

# Render production (set automatically in render.yaml):
# DATABASE_PATH=/opt/render/project/src/data/writeflow.db